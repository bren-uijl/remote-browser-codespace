{
  "name": "Remote Browser",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "noVNC Browser",
      "visibility": "public"
    }
  },
  "postCreateCommand": "chmod +x start.sh",
  "postStartCommand": "./start.sh"
}
